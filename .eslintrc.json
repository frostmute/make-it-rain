{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "project": "./tsconfig.json"
  },
  "env": {
    "browser": true,
    "node": true,
    "es6": true
  },
  "plugins": ["@typescript-eslint", "obsidian", "sentence-case"],
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended",
    "plugin:obsidian/recommended"
  ],
  "rules": {
    "no-constant-condition": "off",
    "obsidian/settings-tab": "off"
  }
}

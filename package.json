{
  "name": "make-it-rain",
  "version": "1.9.0",
  "description": "Pull your Raindrop.io bookmarks with flexible filtering, customization, and location options.",
  "main": "main.js",
  "scripts": {
    "dev": "node scripts/esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node scripts/esbuild.config.mjs production",
    "version": "node scripts/version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint src/ --ext .ts",
    "lint:md": "markdownlint '**/*.md' --fix",
    "copy-to-vault": "node scripts/copy-to-vault.mjs",
    "build-and-copy": "npm run build && npm run copy-to-vault",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose"
  },
  "keywords": [
    "obsidian",
    "raindrop",
    "bookmarks"
  ],
  "author": "frostmute",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.25.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-obsidianmd": "^0.2.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-sentence-case": "^0.0.6",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "markdownlint": "^0.38.0",
    "markdownlint-cli": "^0.45.0",
    "obsidian": "latest",
    "ts-jest": "^29.4.9",
    "tslib": "^2.6.2",
    "typescript": "5.3.3"
  },
  "dependencies": {
    "@types/handlebars": "^4.0.40",
    "handlebars": "^4.7.8"
  }
}
